{
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run format*)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(npm run test*)",
      "Bash(npm run db:*)",
      "Bash(task *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(docker compose *)",
      "Bash(npx prisma *)",
      "Bash(nvm ls:*)",
      "Read(//usr/local/bin/**)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(brew list:*)",
      "Read(//opt/homebrew/Cellar/node@22/22.21.1_4/bin/**)",
      "Bash(PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" node -v)",
      "Bash(PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" npm install @trpc/client@^11.17.0 @trpc/server@^11.17.0 @trpc/next@^11.17.0 @trpc/react-query@^11.17.0)",
      "Bash(git checkout:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/plan-memory-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/plan-memory-reminder.sh"
          }
        ]
      }
    ]
  }
}
