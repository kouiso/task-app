# 現在のブランチ名を取得
current_branch=$(git rev-parse --abbrev-ref HEAD)

# main ブランチ自身の場合はチェックを除外
if [ "$current_branch" = "main" ]; then
  echo "Info: Special branch '$current_branch' - skipping sync check"
  exit 0
fi

# main の最新を取り込んでいるか検証（develop は廃止済み、main 一本運用）
git fetch origin main
if [ -n "$(git log HEAD..origin/main --oneline)" ]; then
  echo ; echo "🚨🚨🚨 Merge the latest main branch before pushing 🚨🚨🚨" ; echo
  exit 1
fi
