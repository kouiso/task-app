#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 変更されたファイルを取得
CHANGED_FILES=$(git diff --name-only --cached)

# Prettier, Stylelint, ESLint の対象ファイルが変更されているか確認し、あれば修正を実行
if echo "$CHANGED_FILES" | grep -E "\.(js|jsx|ts|tsx|json|html|scss)$"; then
  yarn fix
fi

# 差分があるか確認する
if ! git diff --quiet; then
  # 差分があればコミットする
  git add .
  git commit -m "fix: apply linting and style fixes"
fi

# developブランチから最新の変更をフェッチする
git fetch origin develop

# developブランチに対する変更があるか確認する
if [[ $(git log HEAD..origin/develop --oneline) ]]; then
  echo ; echo "🚨🚨🚨 Merge the latest develop branch before pushing 🚨🚨🚨" ; echo
  exit 1
fi

# すべてのチェックが通ればプッシュを許可する
exit 0
