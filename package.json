{
  "name": "horsemanager-web",
  "version": "1.0.0",
  "private": true,
  "description": "HM Frontend Web",
  "author": "KosukeIsogai",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=23.10.0"
  },
  "scripts": {
    "start": "next start",
    "dev": "run-s dev:serve",
    "dev:serve": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "build": "run-s build:*",
    "build:serve": "next build",
    "postbuild": "next-sitemap",
    "compile": "run-s compile:*",
    "compile:aspida": "rm -rf ./src/lib/aspida && npx openapi2aspida -c aspida.config.cjs",
    "compile:orval": "npx orval",
    "fix": "run-p fix:*",
    "fix:eslint": "next lint --fix",
    "fix:prettier": "prettier .  --write",
    "lint": "run-p lint:*",
    "lint:eslint": "next lint",
    "lint:prettier": "prettier . --check",
    "lint:type": "tsc --noEmit",
    "prepare": "husky install",
    "license-check": "license-checker --summary",
    "firebase": "firebase",
    "firebase:emulate": "firebase emulators:start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "config": "lint-staged.config.js"
  },
  "dependencies": {
    "@aspida/axios": "^1.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^3.9.0",
    "@mui/icons-material": "^6.4.8",
    "@mui/material": "^6.4.8",
    "@mui/system": "^6.4.8",
    "@stripe/react-stripe-js": "^2.7.3",
    "@stripe/stripe-js": "^3.5.0",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-query-devtools": "^5.51.16",
    "aspida": "^1.14.0",
    "axios": "^1.7.2",
    "classnames": "^2.5.1",
    "firebase": "^10.8.0",
    "next": "14.2.25",
    "next-auth": "^4.24.7",
    "orval": "^7.7.0",
    "react": "^18",
    "react-cookie": "^7.2.0",
    "react-dom": "^18",
    "react-hook-form": "^7.52.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.25.1",
    "react-toastify": "^11.0.3",
    "react-use": "^17.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^3.0.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^3.0.9",
    "@welldone-software/why-did-you-render": "^8.0.3",
    "cspell": "^8.13.0",
    "eslint": "^8",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "14.2.13",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^8.0.3",
    "jsdom": "^26.0.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.2.7",
    "micromatch": "^4.0.7",
    "next-sitemap": "^4.2.3",
    "npm-run-all": "^4.1.5",
    "openapi2aspida": "^0.24.0",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "^5"
  }
}
