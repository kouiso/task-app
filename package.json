{
  "name": "horsemanager-web",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "next start",
    "dev": "run-s dev:serve",
    "dev:serve": "next dev -p 4000",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "devs:scss": "typed-scss-modules src --watch --nameFormat none",
    "build": "run-s build:*",
    "builds:scss": "typed-scss-modules src",
    "build:serve": "next build",
    "postbuild": "next-sitemap",
    "compile": "run-s compile:*",
    "compile:aspida": "rm -rf ./src/lib/aspida && npx openapi2aspida -c aspida.config.cjs",
    "compile:orval": "npx orval",
    "fix": "run-p fix:*",
    "fix:eslint": "next lint --fix",
    "fix:prettier": "prettier .  --write",
    "fix:stylelint": "stylelint 'src/**/*.css' 'src/**/*.scss' --fix",
    "lint": "run-p lint:*",
    "lint:eslint": "next lint",
    "lint:prettier": "prettier . --check",
    "lint:stylelint": "stylelint 'src/**/*.scss'",
    "prepare": "husky install",
    "license-check": "license-checker --summary",
    "firebase": "firebase",
    "firebase:emulate": "firebase emulators:start"
  },
  "dependencies": {
    "@aspida/axios": "^1.14.0",
    "@hookform/resolvers": "^3.4.2",
    "@stripe/react-stripe-js": "^2.7.1",
    "@stripe/stripe-js": "^3.5.0",
    "@tanstack/react-query": "^5.44.0",
    "@tanstack/react-query-devtools": "^5.44.0",
    "aspida": "^1.14.0",
    "axios": "^1.7.2",
    "firebase": "^10.11.1",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "orval": "^6.31.0",
    "react": "^18.2.0",
    "react-cookie": "^7.1.4",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.5",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.0",
    "react-toastify": "^10.0.5",
    "sanitize.css": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.7",
    "@types/node": "^20",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@welldone-software/why-did-you-render": "^8.0.1",
    "cspell": "^8.8.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^9.0.11",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.2.2",
    "micromatch": "^4.0.5",
    "next-sitemap": "^4.2.3",
    "npm-run-all": "^4.1.5",
    "openapi2aspida": "^0.23.2",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.77.1",
    "stylelint": "^16.5.0",
    "stylelint-config-recommended-scss": "^14.0.0",
    "stylelint-config-sass-guidelines": "^11.1.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.4",
    "stylelint-scss": "^6.3.0",
    "typed-scss-modules": "^8.0.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
