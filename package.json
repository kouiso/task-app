{
  "name": "horsemanager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:*",
    "dev:ssr": "next dev --experimental-https",
    "dev:ssr:http": "next dev",
    "dev:storybook": "npx storybook dev -p 6006",
    "dev:typedoc": "npx http-server typedocs-static -o",
    "build": "yarn install && run-s build:*",
    "build:next": "next build",
    "build:storybook": "npx storybook build -o storybook-static --docs",
    "build:typedoc": "typedoc --out typedocs-static",
    "build:telemetry:off": "npx cap telemetry off",
    "build:copy": "npx cap copy",
    "build-sync": "npx cap sync",
    "check": "run-p check:*",
    "check:next": "next lint",
    "check:js": "npx eslint --ext .tsx,.ts ./",
    "check:style": "npx stylelint **/*.scss",
    "check:prettier": "prettier \"**/*.+(js|jsx|json|ts|tsx|scss|html)\"",
    "fix": "run-p fix:*",
    "fix:next": "next lint --fix",
    "fix:js": "npx eslint --ext .tsx,.ts ./ --fix",
    "fix:style": "npx stylelint **/*.scss --fix",
    "fix:prettier": "prettier --write \"**/*.+(js|jsx|json|ts|tsx|scss|html)\"",
    "test": "run-p test:*",
    "test:jest": "jest",
    "test:e2e": "npx playwright test",
    "deploy:ios": "dotenv cross-var 'firebase appdistribution:distribute $OUTPUT_IOS_PATH --app $VITE_FIREBASE_IOS_APP_ID --release-notes $RELEASE_NOTES --groups $GROUPS'",
    "deploy:android": "dotenv cross-var 'firebase appdistribution:distribute $OUTPUT_ANDROID_PATH --app $VITE_FIREBASE_ANDROID_APP_ID --release-notes $RELEASE_NOTES --groups $GROUPS'",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "chromatic": "npx chromatic --build-script-name build:storybook --force-rebuild --exit-zero-on-changes",
    "analyze": "ANALYZE=true yarn build",
    "postinstall": "husky install",
    "preinstall": "npx only-allow yarn",
    "amplify": "amplify",
    "gql:mock": "amplify mock api"
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/core": "^5.7.0",
    "aws-amplify": "^6.0.16",
    "classnames": "^2.5.1",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@aws-amplify/cli": "^12.10.1",
    "@babel/core": "^7.23.9",
    "@capacitor/android": "^5.7.0",
    "@capacitor/cli": "^5.7.0",
    "@capacitor/ios": "^5.7.0",
    "@next/bundle-analyzer": "^14.1.0",
    "@playwright/test": "^1.41.2",
    "@storybook/addon-essentials": "^7.6.14",
    "@storybook/addon-interactions": "^7.6.14",
    "@storybook/addon-links": "^7.6.14",
    "@storybook/blocks": "^7.6.14",
    "@storybook/nextjs": "^7.6.14",
    "@storybook/react": "^7.6.14",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/babel__core": "^7.20.5",
    "@types/eslint": "^8.56.2",
    "@types/node": "^20.11.17",
    "@types/prettier": "^3.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@welldone-software/why-did-you-render": "^8.0.1",
    "babel-loader": "^9.1.3",
    "chromatic": "^10.9.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-next": "^14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-storybook": "^0.6.15",
    "husky": "^9.0.10",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.41.2",
    "prettier": "^3.2.5",
    "sass": "^1.70.0",
    "sass-loader": "^14.1.0",
    "serve": "^14.2.1",
    "storybook": "^7.6.14",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.8",
    "typescript": "^5.3.3",
    "yarn-run-all": "^3.1.1"
  },
  "volta": {
    "node": "20.11.0",
    "yarn": "4.1.0"
  },
  "packageManager": "yarn@4.1.0"
}
