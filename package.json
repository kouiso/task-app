{
  "name": "horsemanager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:*",
    "dev:ssr": "next dev",
    "dev:ssg": "next start",
    "dev:storybook": "start-storybook -p 6006",
    "dev:typedoc": "npx http-server typedocs-static -o",
    "build": "run-s buildnext:* && run-p build:*",
    "buildnext:ssr": "next build",
    "buildnext:ssg": "next export",
    "build:storybook": "build-storybook -o storybook-static --docs",
    "build:typedoc": "typedoc --out typedocs-static",
    "build:capsync": "npx cap sync",
    "check": "run-p check:*",
    "check:next": "next lint",
    "check:js": "npx eslint --ext .tsx,.ts ./",
    "check:style": "npx stylelint **/*.scss",
    "check:prettier": "prettier \"**/*.+(js|jsx|json|ts|tsx|scss|html)\"",
    "fix": "run-p fix:*",
    "fix:next": "next lint --fix",
    "fix:js": "npx eslint --ext .tsx,.ts ./ --fix",
    "fix:style": "npx stylelint **/*.scss --fix",
    "fix:prettier": "prettier --write \"**/*.+(js|jsx|json|ts|tsx|scss|html)\"",
    "test": "run-p test:*",
    "test:jest": "jest",
    "test:e2e": "npx playwright test",
    "deploy:ios": "dotenv cross-var 'firebase appdistribution:distribute $OUTPUT_IOS_PATH --app $VITE_FIREBASE_IOS_APP_ID --release-notes $RELEASE_NOTES --groups $GROUPS'",
    "deploy:android": "dotenv cross-var 'firebase appdistribution:distribute $OUTPUT_ANDROID_PATH --app $VITE_FIREBASE_ANDROID_APP_ID --release-notes $RELEASE_NOTES --groups $GROUPS'",
    "deploy:storybook": "yarn build:storybook && firebase deploy --only functions",
    "deploy:typedocs": "yarn build:typedoc && firebase deploy --only functions",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "chromatic": "npx chromatic --build-script-name build:storybook --force-rebuild --exit-zero-on-changes",
    "postinstall": "husky install",
    "analyze": "ANALYZE=true yarn build",
    "amplify": "amplify",
    "gql:mock": "amplify mock api"
  },
  "dependencies": {
    "@capacitor-community/electron": "^4.1.2",
    "@capacitor/core": "^4.7.1",
    "@next/font": "13.1.1",
    "aws-amplify": "^5.0.16",
    "classnames": "^2.3.2",
    "next": "13.1.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@aws-amplify/cli": "^10.8.1",
    "@babel/core": "^7.19.0",
    "@capacitor/android": "^4.7.1",
    "@capacitor/cli": "^4.7.1",
    "@capacitor/ios": "^4.7.1",
    "@next/bundle-analyzer": "^12.3.0",
    "@playwright/test": "^1.32.0",
    "@storybook/addon-actions": "^6.5.12",
    "@storybook/addon-essentials": "^6.5.12",
    "@storybook/addon-interactions": "^6.5.12",
    "@storybook/addon-links": "^6.5.12",
    "@storybook/builder-webpack5": "^6.5.12",
    "@storybook/manager-webpack5": "^6.5.12",
    "@storybook/react": "^6.5.12",
    "@storybook/testing-library": "^0.0.13",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@types/babel__core": "^7.20.0",
    "@types/eslint": "^8.4.6",
    "@types/node": "18.11.18",
    "@types/prettier": "^2.7.2",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.10",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^5.36.2",
    "@typescript-eslint/parser": "^5.36.2",
    "babel-loader": "^8.2.5",
    "chromatic": "^6.17.0",
    "eslint": "8.31.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-next": "13.1.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-react": "^7.31.8",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "playwright": "^1.32.0",
    "prettier": "^2.7.1",
    "sass": "^1.57.1",
    "sass-loader": "^13.2.0",
    "sb": "^6.5.12",
    "stylelint": "^15.3.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^30.0.1",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "typedoc": "^0.23.24",
    "typescript": "4.9.4",
    "yarn-run-all": "^3.1.1"
  },
  "volta": {
    "node": "16.17.0",
    "yarn": "1.22.19"
  }
}
