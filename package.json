{
  "name": "task-app",
  "version": "1.0.0",
  "private": true,
  "description": "Task Management App - Educational Material",
  "author": "KosukeIsogai",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.11.0"
  },
  "volta": {
    "node": "22.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "vercel-build": "prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint:ci": "biome ci .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/command/seed.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "postinstall": "prisma generate",
    "vercel:setup": "node setup-vercel-db.mjs",
    "vercel:env": "vercel env pull .env.production.local",
    "vercel:seed": "vercel env pull .env.production.local && npx prisma db seed"
  },
  "lint-staged": {
    "config": "lint-staged.config.js"
  },
  "prisma": {
    "seed": "tsx src/command/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^3.9.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.4.8",
    "@mui/material-nextjs": "^6.4.8",
    "@mui/system": "^6.4.8",
    "@mui/x-data-grid": "^7.24.0",
    "@mui/x-date-pickers": "^7.29.4",
    "@prisma/client": "^6.16.2",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "@trpc/client": "^11.6.0",
    "@trpc/next": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "bcryptjs": "^2.4.3",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "next": "^15.0.0",
    "next-auth": "^4.24.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.2.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^3.0.9",
    "husky": "^8.0.3",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.7",
    "micromatch": "^4.0.7",
    "playwright": "^1.56.1",
    "prisma": "^6.16.2",
    "tsc-files": "^1.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.9"
  }
}
