{
  "name": "horsemanager-web",
  "version": "1.0.0",
  "private": true,
  "description": "HM Frontend Web",
  "author": "KosukeIsogai",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.5.1"
  },
  "scripts": {
    "start": "next start",
    "dev": "run-s dev:serve",
    "dev:serve": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "devs:scss": "typed-scss-modules src --watch --nameFormat none",
    "build": "run-s build:*",
    "builds:scss": "typed-scss-modules src",
    "build:serve": "next build",
    "postbuild": "next-sitemap",
    "compile": "run-s compile:*",
    "compile:aspida": "rm -rf ./src/lib/aspida && npx openapi2aspida -c aspida.config.cjs",
    "compile:orval": "npx orval",
    "fix": "run-p fix:*",
    "fix:eslint": "next lint --fix",
    "fix:prettier": "prettier .  --write",
    "fix:stylelint": "stylelint 'src/**/*.css' 'src/**/*.scss' --fix",
    "lint": "run-p lint:*",
    "lint:eslint": "next lint",
    "lint:prettier": "prettier . --check",
    "lint:stylelint": "stylelint 'src/**/*.scss'",
    "prepare": "husky install",
    "license-check": "license-checker --summary",
    "firebase": "firebase",
    "firebase:emulate": "firebase emulators:start"
  },
  "lint-staged": {
    "config": "lint-staged.config.js"
  },
  "dependencies": {
    "@aspida/axios": "^1.14.0",
    "@hookform/resolvers": "^3.9.0",
    "@stripe/react-stripe-js": "^2.7.3",
    "@stripe/stripe-js": "^3.5.0",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-query-devtools": "^5.51.16",
    "@trpc/client": "^11.0.0-rc.502",
    "@trpc/next": "^11.0.0-rc.502",
    "@trpc/react-query": "^11.0.0-rc.502",
    "@trpc/server": "^11.0.0-rc.502",
    "aspida": "^1.14.0",
    "axios": "^1.7.2",
    "firebase": "^10.12.4",
    "next": "14.2.13",
    "next-auth": "^4.24.7",
    "orval": "^6.31.0",
    "react": "^18",
    "react-cookie": "^7.2.0",
    "react-dom": "^18",
    "react-hook-form": "^7.52.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.25.1",
    "react-toastify": "^10.0.5",
    "sanitize.css": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@welldone-software/why-did-you-render": "^8.0.3",
    "cspell": "^8.13.0",
    "eslint": "^8",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "14.2.13",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^8.0.3",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.2.7",
    "micromatch": "^4.0.7",
    "next-sitemap": "^4.2.3",
    "npm-run-all": "^4.1.5",
    "openapi2aspida": "^0.24.0",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.77.8",
    "stylelint": "^16.8.1",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-sass-guidelines": "^11.1.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-order": "^6.0.4",
    "stylelint-scss": "^6.4.1",
    "typed-scss-modules": "^8.0.1",
    "typescript": "^5"
  }
}
