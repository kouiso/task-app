{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "dependencyDashboard": false,
  "rebaseWhen": "never",
  "schedule": [
    "before 3am on Monday"
  ],
  "prHourlyLimit": 10,
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "7 days",
  "labels": [
    "renovate"
  ],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "groupName": "リンター関連パッケージ",
      "matchPackagePatterns": [
        "eslint",
        "prettier",
        "stylelint"
      ]
    },
    {
      "groupName": "型定義パッケージ",
      "matchPackagePatterns": [
        "^@types/"
      ]
    },
    {
      "managers": [
        "npm"
      ],
      "matchPackageNames": [
        "*"
      ],
      "matchDepTypes": [
        "dependencies"
      ],
      "groupName": "本番環境依存関係",
      "groupSlug": "production-dependencies",
      "automerge": false
    },
    {
      "managers": [
        "npm"
      ],
      "matchPackageNames": [
        "*"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "groupName": "開発環境依存関係",
      "groupSlug": "dev-dependencies",
      "automerge": false
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "labels": [
        "renovate",
        "github-actions"
      ]
    }
  ],
  "npm": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  }
}