{
  "extends": [
    "config:base"
  ],
  "schedule": [
    "monthly on saturday"
  ],
  "automerge": true,
  "automergeType": "pr",
  "requiredStatusChecks": null,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 5,
  "dependencyDashboard": true,
  "dependencyDashboardAutoclose": true,
  "dependencyDashboardTitle": "📦 依存関係アップデートダッシュボード",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "groupName": "非メジャーアップデート"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "major-update"
      ]
    },
    {
      "matchUpdateTypes": [
        "security"
      ],
      "matchVulnerabilitySeverity": [
        "critical",
        "high"
      ],
      "automerge": true,
      "prPriority": 1,
      "labels": [
        "security"
      ]
    },
    {
      "matchPackagePatterns": [
        "eslint",
        "prettier",
        "stylelint"
      ],
      "groupName": "リンター関連パッケージ"
    },
    {
      "matchPackagePatterns": [
        "^@types/"
      ],
      "groupName": "型定義パッケージ"
    }
  ],
  "npm": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  }
}