{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Next.js Server",
      "skipFiles": ["<node_internals>/**"],
      "port": 19229,
      "address": "localhost",
      "restart": true,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/app",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/.next/**/*.js", "!**/node_modules/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:14000",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
