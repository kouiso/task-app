# Database (PostgreSQL)
# For local development, use a local PostgreSQL instance or Docker
# DATABASE_URL="postgresql://user:password@localhost:5432/taskapp?schema=public"
# For Vercel Postgres
# DATABASE_URL="postgres://default:xxx@xxx.postgres.vercel-storage.com:5432/verceldb?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/taskapp?schema=public"

# JWT Authentication
JWT_SECRET="your-secret-key-here-please-change-in-production"

# App
NODE_ENV="development"

# AI Provider API Keys
OPENAI_API_KEY=""
