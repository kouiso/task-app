# Database (PostgreSQL)
# For local development, use a local PostgreSQL instance or Docker
# DATABASE_URL="postgresql://user:password@localhost:5432/taskapp?schema=public"
# For Vercel Postgres
# DATABASE_URL="postgres://default:xxx@xxx.postgres.vercel-storage.com:5432/verceldb?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/taskapp?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-32-chars-minimum-please-change"

# JWT Authentication
JWT_SECRET="your-jwt-secret-key-32-chars-minimum-please-change"

# App
NODE_ENV="development"
